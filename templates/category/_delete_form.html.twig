<form method="post" action="{{ path('app_category_delete', {'id': category.id}) }}" onsubmit="return confirm('🚮 Voulez-vous vraiment supprimer cette catégorie ? Tous les produits associés seront supprimés.');", style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
    <button type="submit" class="btn btn-sm btn-danger rounded-3" style="font-weight: 500;">Supprimer</button>
</form>
