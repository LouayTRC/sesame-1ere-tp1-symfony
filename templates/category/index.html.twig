{% extends 'base.html.twig' %}

{% block title %}Catégories{% endblock %}

{% block body %}
    <div>
        <div class="row mb-5 align-items-end">
            <div class="col">
                <h1 class="display-5" style="font-weight: 700; color: #333;">📁 Catégories</h1>
                <p class="text-muted">Organisez vos produits par catégories</p>
            </div>
            <div class="col-auto">
                <a class="btn rounded-3" href="{{ path('app_category_new') }}" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; font-weight: 500; padding: 8px 24px;">+ Nouvelle catégorie</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead style="background-color: #f8f9fa;">
                            <tr>
                                <th style="width:60px; font-weight: 600; color: #333;">🏷️ Id</th>
                                <th style="font-weight: 600; color: #333;">Libelle</th>
                                <th style="width:140px; font-weight: 600; color: #333;">Produits</th>
                                <th style="width:180px; font-weight: 600; color: #333;">Date de création</th>
                                <th style="width:150px; font-weight: 600; color: #333;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for category in categories %}
                            <tr style="border-bottom: 1px solid #eee;">
                                <td class="align-middle" style="font-weight: 600; color: #667eea;">#{{ category.id }}</td>
                                <td class="align-middle">{{ category.libelle }}</td>
                                <td class="align-middle">
                                    <span class="badge rounded-pill" style="background-color: #667eea; padding: 6px 12px;">{{ category.products|length }}</span>
                                </td>
                                <td class="align-middle text-muted">{{ category.createdAt ? category.createdAt|date('d/m/Y') : '—' }}</td>
                                <td class="align-middle">
                                    <a class="btn btn-sm rounded-3" href="{{ path('app_category_show', {'id': category.id}) }}" style="background-color: #667eea; color: white; border: none; font-weight: 500;">Voir</a>
                                    <a class="btn btn-sm btn-outline-secondary rounded-3" href="{{ path('app_category_edit', {'id': category.id}) }}">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">Aucune catégorie trouvée. <a href="{{ path('app_category_new') }}" style="font-weight: 600;">Créer la première</a></td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
