{% extends 'base.html.twig' %}

{% block title %}Nouveau produit{% endblock %}

{% block body %}
    <div>
        <div class="row mb-5">
            <div class="col">
                <a href="{{ path('app_product_index') }}" class="btn btn-sm btn-outline-secondary" style="margin-bottom: 16px;">← Retour</a>
                <h1 class="display-5" style="font-weight: 700; color: #333;">🛍️ Créer un produit</h1>
                <p class="text-muted">Ajoutez un nouveau produit à votre catalogue</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 offset-md-2">
                {{ include('product/_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
