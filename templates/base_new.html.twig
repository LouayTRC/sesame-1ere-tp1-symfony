<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Gestionnaire de Produits{% endblock %}</title>

        {# Favicon #}
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📦</text></svg>">

        {# Bootstrap 5 CSS #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {# Bootstrap Icons #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
        
        {# Custom CSS #}
        <link href="{{ asset('styles/custom.css') }}" rel="stylesheet">

        {% block stylesheets %}{% endblock %}

        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body class="bg-light">
        <div class="container-fluid">
            <div class="row" style="min-height: 100vh;">
                <nav class="col-2 bg-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); position: sticky; top: 0; height: 100vh; overflow-y: auto;">
                    {% block sidebar %}
                        <div class="p-4">
                            <h4 class="text-white mb-4" style="font-weight: 700; letter-spacing: 0.5px;">🚀 Manage</h4>
                            <ul class="nav flex-column gap-2">
                                <li class="nav-item">
                                    <a class="nav-link text-white rounded-3 px-3 py-2" style="transition: all 0.3s; background-color: rgba(255,255,255,0.1);" href="{{ path('home') }}" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.2)'" onmouseout="this.style.backgroundColor='rgba(255,255,255,0.1)'">
                                        <i class="bi bi-house-fill"></i> Accueil
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white rounded-3 px-3 py-2" style="transition: all 0.3s; background-color: rgba(255,255,255,0.1);" href="{{ path('app_category_index') }}" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.2)'" onmouseout="this.style.backgroundColor='rgba(255,255,255,0.1)'">
                                        <i class="bi bi-folder-fill"></i> Catégories
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white rounded-3 px-3 py-2" style="transition: all 0.3s; background-color: rgba(255,255,255,0.1);" href="{{ path('app_product_index') }}" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.2)'" onmouseout="this.style.backgroundColor='rgba(255,255,255,0.1)'">
                                        <i class="bi bi-bag-fill"></i> Produits
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white rounded-3 px-3 py-2" style="transition: all 0.3s; background-color: rgba(255,255,255,0.1);" href="{{ path('app_qualite_index') }}" onmouseover="this.style.backgroundColor='rgba(255,255,255,0.2)'" onmouseout="this.style.backgroundColor='rgba(255,255,255,0.1)'">
                                        <i class="bi bi-star-fill"></i> Qualités
                                    </a>
                                </li>
                            </ul>
                        </div>
                    {% endblock %}
                </nav>

                <main class="col py-4 px-5">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>

        {# Bootstrap 5 JS Bundle (inclut Popper) #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        {% block javascripts %}{% endblock %}
    </body>
</html>
